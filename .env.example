# App
APP_NAME=Freight Bill Processor
DEBUG=false
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_NAME=app.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5

# Database
# Set in GCP Secret Manager for Cloud Run
DATABASE_URL=

# LLM
# Choose one: openai or anthropic
LLM_PROVIDER=openai
LLM_OPENAI_MODEL=gpt-4o-mini
LLM_ANTHROPIC_MODEL=claude-3-5-haiku-latest
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_DEBUG_PAYLOADS=false
LLM_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
MAX_CONCURRENT_AGENT_RUNS=8
BULK_INGEST_BATCH_SIZE=250

# Multi-tenancy
DEFAULT_TENANT_ID=default

# Graph backend
# Use neo4j in production. Use memory only for local tests without Neo4j.
GRAPH_BACKEND=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50

# Agent thresholds
AUTO_APPROVE_THRESHOLD=0.85
DISPUTE_THRESHOLD=0.40
