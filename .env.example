# App
APP_NAME=Freight Bill Processor
DEBUG=false
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_NAME=app.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5

# Database
# Set in GCP Secret Manager for Cloud Run
DATABASE_URL=

# LLM
# Choose one: openai or anthropic
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_DEBUG_PAYLOADS=false
LLM_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
MAX_CONCURRENT_AGENT_RUNS=8

# Agent thresholds
AUTO_APPROVE_THRESHOLD=0.85
DISPUTE_THRESHOLD=0.40
